# =========================

# ReCircle - .gitignore

# =========================

# Dependencies

node_modules/
**/node_modules/

# Environment variables

.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# AWS credentials

.aws/
credentials

# Logs

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime files

pids/
*.pid
*.seed
*.pid.lock

# Build outputs

dist/
build/
out/

# Vite

.vite/

# Coverage

coverage/
.nyc_output/

# Cache

.cache/
.parcel-cache/
.eslintcache

# OS files

.DS_Store
Thumbs.db

# IDE

.vscode/
.idea/
*.swp
*.swo

# Temporary files

tmp/
temp/

# Uploaded files

uploads/
public/uploads/

# DynamoDB local

.dynamodb/

# AWS SAM / Serverless

.aws-sam/
.serverless/

# Generated QR codes

qrcodes/
qr/
generated/

# Test files

*.test.js.snap

# Secrets

*.pem
*.key
*.crt
*.p12

# Terraform

.terraform/
*.tfstate
*.tfstate.*

# Misc

*.zip
*.tar
*.gz

# React build artifacts

client/build/
client/dist/

# Backend build artifacts

server/build/
server/dist/

# Local database files

*.sqlite
*.db
*.sqlite3

# Ignore backend env

server/.env

# Ignore frontend env

client/.env
